rule detect_primer_offsets:
    """
    Generalized primer offset detection for multi-primer-pair amplicon sequencing.

    Automatically:
    1. Detects UMI presence and length for each primer pair
    2. Finds the common core sequence shared by all primer pairs
    3. Calculates optimal 5' trim lengths for cache sharing

    Works with any number of primer pairs amplifying the same locus.
    """
    input:
        manifest = MANIFEST
    output:
        trim_config = CACHE_DIR / "primer_config.json"
    log:
        CACHE_DIR / "detect_primer_offsets.log"
    script:
        str(WORKFLOW_DIR / "scripts" / "detect_primer_offsets.py")


def get_trim_inputs(wildcards):
    """Get input files for trimming, handling single-end samples."""
    sample = wildcards.sample
    inputs = {'r1': sample_info[sample]['r1_path']}
    if not is_single_end(sample):
        inputs['r2'] = sample_info[sample]['r2_path']
    return inputs


rule trim_adapters:
    """Trim adapters using cutadapt. Handles both single-end and paired-end."""
    input:
        unpack(get_trim_inputs)
    output:
        r1 = SAMPLES_DIR / "{sample}" / "trimmed" / "R1_trimmed.fastq.gz",
        r2 = SAMPLES_DIR / "{sample}" / "trimmed" / "R2_trimmed.fastq.gz"
    log:
        SAMPLES_DIR / "{sample}" / "logs" / "trim.log"
    params:
        is_single_end = lambda w: is_single_end(w.sample),
        r2_input = lambda w, input: getattr(input, 'r2', '')
    threads: 2
    shell:
        """
        mkdir -p $(dirname {output.r1})
        if [ "{params.is_single_end}" = "True" ]; then
            # Single-end mode
            cutadapt \
                -a AGATCGGAAGAGCACACGTCTGAACTCCAGTCA \
                -j {threads} \
                -m 20 \
                -o {output.r1} \
                {input.r1} \
                > {log} 2>&1
            # Create empty R2 for workflow compatibility
            echo -n | gzip > {output.r2}
        else
            # Paired-end mode
            cutadapt \
                -a AGATCGGAAGAGCACACGTCTGAACTCCAGTCA \
                -A AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT \
                -j {threads} \
                -m 20 \
                -o {output.r1} \
                -p {output.r2} \
                {input.r1} {params.r2_input} \
                > {log} 2>&1
        fi
        """


