rule extract_global_unique_sequences:
    """
    Level 1 Cache: Extract globally unique READ SEQUENCES (ignoring guide/donor).
    These will be aligned once.

    SQLite-based for low memory usage (~50MB vs 22GB for large datasets).
    """
    input:
        collapsed = expand(SAMPLES_DIR / "{sample}" / "collapsed" / "unique_sequences.tsv.gz", sample=SAMPLES)
    output:
        unique_seqs = CACHE_DIR / "level1_unique_sequences.tsv.gz",
        seq_to_samples = CACHE_DIR / "level1_seq_to_samples.tsv.gz",
        sqlite_cache = CACHE_DIR / "level1_cache.db"
    log:
        CACHE_DIR / "extract_unique.log"
    script:
        str(WORKFLOW_DIR / "scripts" / "extract_global_unique_seqs.py")


rule create_reference_fasta:
    """Create reference FASTA for aligners."""
    output:
        fasta = OUTPUT_DIR / "reference.fasta"
    run:
        import sys
        sys.path.insert(0, str(WORKFLOW_DIR.parent))
        from trace_crispr.config import parse_sequence_input

        ref_seq = None
        for sample_id in SAMPLES:
            ref = sample_info[sample_id]['reference']
            if ref and not pd.isna(ref):
                ref_seq = parse_sequence_input(ref)
                break

        if ref_seq is None and DEFAULT_REF:
            ref_seq = parse_sequence_input(DEFAULT_REF)

        if ref_seq is None:
            raise ValueError("No reference sequence found")

        output_path = Path(output.fasta)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(f">reference\n{ref_seq}\n")


