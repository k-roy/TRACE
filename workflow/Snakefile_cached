def get_samples_for_combo(combo_id):
    """Get list of sample IDs that use a specific (guide, donor) combination."""
    guide, donor = COMBO_IDS[combo_id]
    return [
        s for s in SAMPLES
        if sample_info[s]['guide'] == guide and sample_info[s]['hdr_template'] == donor
    ]


def get_combo_outputs(combo_id):
    """Get list of output files produced by classify_group for this combo."""
    samples = get_samples_for_combo(combo_id)
    outputs = []
    for s in samples:
        outputs.append(SAMPLES_DIR / s / "classification.tsv")
        outputs.append(SAMPLES_DIR / s / "hdr_snv_detail.tsv")
    return outputs


rule classify_group:
    """
    Memory-efficient classification: process all samples for a (guide, donor) group
    in a single script invocation.

    Benefits over per-sample expansion:
    - Loads Level 1 alignment cache once via SQLite (~50MB vs 12GB)
    - Builds Level 2 classification cache incrementally in memory
    - Checkpoint-based resumability
    - 14 parallel jobs instead of 484 (for LGC dataset)
    """
    input:
        alignment_cache = CACHE_DIR / "level1_alignment_cache.tsv.gz",
        collapsed = lambda w: expand(
            SAMPLES_DIR / "{sample}" / "collapsed" / "unique_sequences.tsv.gz",
            sample=get_samples_for_combo(w.combo_id)
        )
    output:
        # Dynamic output: all sample classification files for this combo
        marker = CACHE_DIR / "groups" / "{combo_id}.done"
    log:
        CACHE_DIR / "classify_group_{combo_id}.log"
    params:
        guide = lambda w: COMBO_IDS[w.combo_id][0],
        donor = lambda w: COMBO_IDS[w.combo_id][1],
        reference = DEFAULT_REF,
        snv_distance_filter = config.get("snv_distance_filter", 50),
        manifest = MANIFEST,
        samples_dir = SAMPLES_DIR,
        output_dir = OUTPUT_DIR
    shell:
        """
        python {WORKFLOW_DIR}/scripts/classify_group.py \
            --combo-id {wildcards.combo_id} \
            --guide "{params.guide}" \
            --donor "{params.donor}" \
            --reference "{params.reference}" \
            --manifest {params.manifest} \
            --alignment-cache {input.alignment_cache} \
            --output-dir {params.output_dir} \
            --samples-dir {params.samples_dir} \
            --snv-distance-filter {params.snv_distance_filter} \
            > {log} 2>&1

        # Create marker file on success
        mkdir -p $(dirname {output.marker})
        echo "Completed at $(date)" > {output.marker}
        echo "Samples: $(ls {params.output_dir}/samples/*/classification.tsv 2>/dev/null | wc -l)" >> {output.marker}
        """


