        *expand(CACHE_DIR / "groups" / "{combo_id}.done", combo_id=COMBO_IDS.keys()),
    ]
    if RUN_CRISPRESSO:
        outputs.append(CRISPRESSO_DIR / "CRISPRessoBatch_done.txt")
