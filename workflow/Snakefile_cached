"""
Snakemake workflow for TRACE analysis with two-level caching.

Level 1 Cache (Alignment): read_seq -> alignment result
  - Shared across ALL samples (reference is constant)
  - Each unique sequence aligned exactly once

Level 2 Cache (Classification): (read_seq, guide, donor) -> outcome
  - Computed per unique (guide, donor) combination
  - Reuses alignment from Level 1

Workflow:
1. Trim adapters (per-sample)
2. Extract unique read sequences globally (ignoring guide/donor)
3. Align unique sequences once (Level 1 cache)
4. For each unique (guide, donor) combination, classify relevant sequences
5. Expand classifications back to per-sample results

Author: Kevin R. Roy
"""

import pandas as pd
from pathlib import Path

# Load configuration
MANIFEST = config.get("manifest", "trace_manifest.tsv")
OUTPUT_DIR = Path(config.get("output_dir", "results/trace_cached_v2"))
THREADS_PER_SAMPLE = config.get("threads_per_sample", 4)
CRISPRESSO_DIR = OUTPUT_DIR / "crispresso_batch"  # Now generated by workflow
RUN_CRISPRESSO = config.get("run_crispresso", True)  # Enable CRISPRessoBatch by default
CRISPRESSO_THREADS = config.get("crispresso_threads", 16)  # Threads for CRISPRessoBatch

# Load sample manifest
manifest_df = pd.read_csv(MANIFEST, sep='\t')
SAMPLES = manifest_df['sample_id'].tolist()

# Create sample info lookup
sample_info = {}
for _, row in manifest_df.iterrows():
    sample_info[row['sample_id']] = {
        'r1_path': row['r1_path'],
        'r2_path': row['r2_path'] if pd.notna(row['r2_path']) else '',
        'reference': row.get('reference', ''),
        'guide': str(row.get('guide', '')) if pd.notna(row.get('guide', '')) else '',
        'hdr_template': str(row.get('hdr_template', '')) if pd.notna(row.get('hdr_template', '')) else '',
    }

# Default sequences - extract from manifest if not in config
DEFAULT_REF = config.get("default_reference", "")
DEFAULT_GUIDE = config.get("default_guide", "")
DEFAULT_HDR = config.get("default_hdr_template", "")

# If no default reference in config, get it from the first sample in manifest
if not DEFAULT_REF:
    for sample_id, info in sample_info.items():
        ref = info['reference']
        if ref and str(ref) != 'nan' and ref.strip():
            DEFAULT_REF = ref.strip()
            break

# Identify unique (guide, donor) combinations for Level 2 cache
guide_donor_combos = set()
for sample_id, info in sample_info.items():
    guide = info['guide'] if info['guide'] and info['guide'] != 'nan' else ''
    donor = info['hdr_template'] if info['hdr_template'] and info['hdr_template'] != 'nan' else ''
    guide_donor_combos.add((guide, donor))

# Create combo IDs for file naming
import hashlib
def combo_id(guide, donor):
    key = f"{guide}|{donor}"
    return hashlib.md5(key.encode()).hexdigest()[:12]

COMBO_IDS = {combo_id(g, d): (g, d) for g, d in guide_donor_combos}

# Create reverse lookup: (guide, donor) -> combo_id
GUIDE_DONOR_TO_COMBO = {(g, d): cid for cid, (g, d) in COMBO_IDS.items()}

# Identify single-end vs paired-end samples
def is_single_end(sample_id):
    """Check if a sample is single-end (no R2 path)."""
    r2 = sample_info[sample_id]['r2_path']
    return not r2 or r2 == '' or str(r2) == 'nan'

SINGLE_END_SAMPLES = [s for s in SAMPLES if is_single_end(s)]
PAIRED_END_SAMPLES = [s for s in SAMPLES if not is_single_end(s)]

# Get workflow directory
WORKFLOW_DIR = Path("/oak/stanford/groups/larsms/Users/kevinroy/software/trace/workflow")
SAMPLES_DIR = OUTPUT_DIR / "samples"
CACHE_DIR = OUTPUT_DIR / "cache"


