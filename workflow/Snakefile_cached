rule generate_crispresso_batch_settings:
    """
    Generate CRISPRessoBatch settings TSV from manifest.

    Creates per-sample settings with amplicon sequences extracted around guide sites.
    Runs after trimming so FASTQs are ready.
    """
    input:
        manifest = MANIFEST,
        trimmed = expand(SAMPLES_DIR / "{sample}" / "trimmed" / "R1_trimmed.fastq.gz", sample=SAMPLES)
    output:
        batch_settings = CRISPRESSO_DIR / "crispresso_batch_settings.tsv"
    log:
        CRISPRESSO_DIR / "generate_batch_settings.log"
    params:
        samples = SAMPLES,
        samples_dir = SAMPLES_DIR,
        default_reference = DEFAULT_REF,
        default_guide = DEFAULT_GUIDE,
        default_hdr = DEFAULT_HDR
    script:
        str(WORKFLOW_DIR / "scripts" / "generate_crispresso_batch_settings.py")


rule run_crispresso_batch:
    """
    Run CRISPRessoBatch for efficient parallel processing.

    Benefits over individual CRISPResso runs:
    - Sequence caching (identical reads aligned once across all samples)
    - Parallel processing (-p flag)

    Runs in PARALLEL with TRACE triple aligner (both start after trimming).
    """
    input:
        batch_settings = CRISPRESSO_DIR / "crispresso_batch_settings.tsv"
    output:
        done = CRISPRESSO_DIR / "CRISPRessoBatch_done.txt"
    log:
        CRISPRESSO_DIR / "crispresso_batch.log"
    threads: CRISPRESSO_THREADS
    shell:
        """
        # Run CRISPRessoBatch
        CRISPRessoBatch \
            --batch_settings {input.batch_settings} \
            --output_folder {CRISPRESSO_DIR} \
            -p {threads} \
            --suppress_report \
            --min_frequency_alleles_around_cut_to_plot 0.05 \
            > {log} 2>&1

        # Create completion marker
        echo "CRISPRessoBatch completed at $(date)" > {output.done}
        echo "Samples processed: $(wc -l < {input.batch_settings})" >> {output.done}
        """


